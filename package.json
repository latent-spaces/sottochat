{
  "name": "sottochat",
  "version": "0.1.4",
  "description": "A quiet back-channel for long autonomous agent runs — tails Claude Code / Codex transcripts and gives you a multilingual Q&A thread about each session.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sottochat": "src/cli.ts"
  },
  "files": [
    "src",
    "public",
    ".env.example",
    "DESIGN.md",
    "PRODUCT.md"
  ],
  "homepage": "https://github.com/latent-spaces/sottochat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/latent-spaces/sottochat.git"
  },
  "bugs": {
    "url": "https://github.com/latent-spaces/sottochat/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude-code",
    "codex",
    "agent",
    "transcript",
    "jsonl",
    "bun"
  ],
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "bun src/cli.ts",
    "build:binary": "bun build --compile --minify src/cli.ts --outfile dist/sottochat",
    "pack:check": "bun pm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@anthropic-ai/sdk": "^0.92.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.5.0"
  }
}
