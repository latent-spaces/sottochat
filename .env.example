# Anthropic auth for the chat/observer subprocesses (Claude Agent SDK).
# Not needed if you're already logged in to Claude Code on this machine.
# ANTHROPIC_API_KEY=sk-ant-...

# Server
# META_PORT=3737                  # HTTP/websocket port (also honors PORT)
# META_POLL_MS=500                # transcript poll interval

# Discovery / inbox
# META_PROJECT_SLUG=              # restrict to one Claude Code project slug
# META_INBOX_MINUTES=240          # how far back the inbox looks
# META_USE_PROCESS_DISCOVERY=1    # scan running processes for sessions (0 to disable)
# META_DISCOVERY_GRACE_MINUTES=30 # keep sessions visible after their process exits

# Chat / observer subprocesses
# META_OBSERVER_ENABLED=1         # background session summarizer (0 to disable)
# META_OBSERVER_MODEL=claude-sonnet-5
# META_CHAT_MODEL=claude-sonnet-5
# META_OBSERVER_BATCH_MS=30000
# META_OBSERVER_FRESH_MS=300000    # ignore older turns during startup backfill
# META_EXPLAIN_LANG=zh            # default Q&A language (switchable in the UI)

# Turn-magnitude thresholds (what counts as a "big" turn)
# META_MAGNITUDE_TOK=1500
# META_MAGNITUDE_TC=5
# META_MAGNITUDE_CHARS=6000
